# === 默认主力模型 (便宜，中文好) ===
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat

# === 备用：OpenAI 兼容 API ===
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# === 备用：Anthropic (复杂推理任务) ===
ANTHROPIC_API_KEY=sk-ant-your-key

# === 可选：Serper 搜索 (不填则用免费 DuckDuckGo) ===
SERPER_API_KEY=

# === LLM 策略 ===
# 简单/工具型 Agent 用哪个模型: deepseek | openai | anthropic
SIMPLE_LLM_PROVIDER=deepseek
# 复杂推理 Agent 用哪个模型: deepseek | openai | anthropic
COMPLEX_LLM_PROVIDER=deepseek
